# OpenRouter API Key
OPENROUTER_API_KEY=your_openrouter_key_here

# Model to use (via OpenRouter)
LLM_MODEL=anthropic/claude-sonnet-4-20250514

# TTL for cached TDPs in days (default 90 = quarterly)
TDP_TTL_DAYS=90

# Server config
HOST=0.0.0.0
PORT=8000

# Integrations
# ClearSignals Railway URL — for thread analysis proxy (POST /api/v1/analyze-thread)
CLEARSIGNALS_URL=https://your-clearsignals-app.up.railway.app

# OppIntelAI public URL — embedded in generated HTML reports for API callbacks
OPPINTELAI_PUBLIC_URL=https://oppintelai.com
